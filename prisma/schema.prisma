generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  name String
  username String @unique
  email String @unique
  password String
  solves Solves[]
}

model Tasks {
  id String @id @default(uuid())
  title String
  description String
  links String[]
  files String[]
  author String
  flag String
}

model Solves{
  id Int @id @default(autoincrement())
  taskId String
  userId String
  user User @relation(fields: [userId], references:[id], ondelete: Cascade)
}